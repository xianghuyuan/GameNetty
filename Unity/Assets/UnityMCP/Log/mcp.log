Engine.Vector2(-20f, -20f)), \"暂无发射器\", 20, UnityEngine.Color.white, TMPro.TextAlignmentOptions.Center);\n    UnityEngine.GameObject buffRoot = makeRect(\"m_tfbuff\", itemVehicle.transform, new UnityEngine.Vector2(0f, 1f), new UnityEngine.Vector2(0f, 1f), new UnityEngine.Vector2(18f, -18f), new UnityEngine.Vector2(96f, 32f));\n    addImage(makeRect(\"m_gobuff\", buffRoot.transform, new UnityEngine.Vector2(0f, 0.5f), new UnityEngine.Vector2(0f, 0.5f), new UnityEngine.Vector2(16f, 0f), new UnityEngine.Vector2(32f, 32f)), new UnityEngine.Color(0.35f, 0.7f, 1f, 1f), true);\n\n    UnityEngine.GameObject gear = makeRect(\"m_btnGear\", root.transform, UnityEngine.Vector2.one, UnityEngine.Vector2.one, new UnityEngine.Vector2(-62f, -52f), new UnityEngine.Vector2(96f, 56f));\n    UnityEngine.UI.Image gearImage = addImage(gear, new UnityEngine.Color(0.15f, 0.28f, 0.46f, 0.95f), true);\n    GameLogic.UIButton gearButton = gear.AddComponent<GameLogic.UIButton>();\n    gearButton.targetGraphic = gearImage;\n    addText(makeRect(\"m_tmpLabel\", gear.transform, UnityEngine.Vector2.zero, UnityEngine.Vector2.one, UnityEngine.Vector2.zero, UnityEngine.Vector2.zero), \"添加\\n发射器\", 18, UnityEngine.Color.white, TMPro.TextAlignmentOptions.Center);\n\n    GameLogic.UIBindComponent bind = root.GetComponent<GameLogic.UIBindComponent>();\n    if (bind == null) bind = root.AddComponent<GameLogic.UIBindComponent>();\n    UnityEditor.SerializedObject so = new UnityEditor.SerializedObject(bind);\n    UnityEditor.SerializedProperty components = so.FindProperty(\"m_components\");\n    components.arraySize = 6;\n    components.GetArrayElementAtIndex(0).objectReferenceValue = bossHp.GetComponent<UnityEngine.RectTransform>();\n    components.GetArrayElementAtIndex(1).objectReferenceValue = bossFill;\n    components.GetArrayElementAtIndex(2).objectReferenceValue = player.GetComponent<UnityEngine.RectTransform>();\n    components.GetArrayElementAtIndex(3).objectReferenceValue = playerFill;\n    componen