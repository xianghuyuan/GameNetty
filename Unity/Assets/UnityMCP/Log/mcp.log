ase.SaveAssets();\nUnityEditor.AssetDatabase.Refresh();\nreturn \"Imported 7 sprites and updated BattleMainWindow prefab HP/Boss/Wave image bindings.\";\n","safety_checks":true,"compiler":"auto"}}
