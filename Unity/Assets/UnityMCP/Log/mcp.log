{"ts":"2026-06-16T10:14:35.858Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":704,"action":"execute","params":{"action":"execute","code":"string path = \"Assets/AssetRaw/UI/Battle/BattleEmitterAddPanelWidget.prefab\";\nvar root = UnityEditor.PrefabUtility.LoadPrefabContents(path);\nif (root == null) return \"Prefab not found\";\n\nSystem.Func<UnityEngine.Transform, string, UnityEngine.Transform> find = null;\nfind = (node, name) => {\n    if (node.name == name) return node;\n    for (int i = 0; i < node.childCount; i++)\n    {\n        var found = find(node.GetChild(i), name);\n        if (found != null) return found;\n    }\n    return null;\n};\n\nSystem.Action<string, UnityEngine.Vector2, UnityEngine.Vector2> setRect = (name, size, pos) => {\n    var rt = find(root.transform, name) as UnityEngine.RectTransform;\n    if (rt == null) throw new System.Exception(\"Missing RectTransform: \" + name);\n    rt.sizeDelta = size;\n    rt.anchoredPosition = pos;\n};\n\nSystem.Action<string, float, UnityEngine.Vector2, UnityEngine.Vector2, bool> setText = (name, fontSize, size, pos, wrap) => {\n    var t = find(root.transform, name);\n    if (t == null) throw new System.Exception(\"Missing text: \" + name);\n    var text = t.GetComponent<TMPro.TextMeshProUGUI>();\n    if (text == null) throw new System.Exception(\"Missing TextMeshProUGUI: \" + name);\n    text.fontSize = fontSize;\n    text.enableAutoSizing = false;\n    text.enableWordWrapping = wrap;\n    text.overflowMode = TMPro.TextOverflowModes.Ellipsis;\n    var rt = t as UnityEngine.RectTransform;\n    if (rt == null) throw new System.Exception(\"Missing RectTransform: \" + name);\n    rt.sizeDelta = size;\n    rt.anchoredPosition = pos;\n};\n\ntry\n{\n    var scroll = find(root.transform, \"m_scrollEmitterOptions\");\n    if (scroll == null) throw new System.Exception(\"Missing m_scrollEmitterOptions\");\n    var scrollRect = scroll.GetComponent<UnityEngine.UI.ScrollRect>();\n    if (scrollRect == null) throw new System.Exception(\"Missing ScrollRect on m_scrollEmitterOptions\");\n    scrollRect.scrollSensitivity = 32f;\n\n    var slots = find(root.transform, \"m_tfEmitterSlots\");\n    if (slots == null) throw new System.Exception(\"Missing m_tfEmitterSlots\");\n    var grid = slots.GetComponent<UnityEngine.UI.GridLayoutGroup>();\n    if (grid == null) throw new System.Exception(\"Missing GridLayoutGroup: m_tfEmitterSlots\");\n    grid.cellSize = new UnityEngine.Vector2(244f, 178f);\n    grid.spacing = new UnityEngine.Vector2(10f, 10f);\n    grid.constraint = UnityEngine.UI.GridLayoutGroup.Constraint.FixedColumnCount;\n    grid.constraintCount = 3;\n    grid.startAxis = UnityEngine.UI.GridLayoutGroup.Axis.Horizontal;\n\n    setRect(\"m_itemEmitterSlot\", new UnityEngine.Vector2(244f, 178f), new UnityEngine.Vector2(0f, 0f));\n    setRect(\"m_imgCooldownFill\", new UnityEngine.Vector2(244f, 178f), new UnityEngine.Vector2(0f, 0f));\n    setText(\"m_tmpName\", 18f, new UnityEngine.Vector2(224f, 28f), new UnityEngine.Vector2(10f, -10f), false);\n    setText(\"m_tmpMeta\", 13f, new UnityEngine.Vector2(224f, 44f), new UnityEngine.Vector2(10f, -42f), true);\n    setText(\"m_tmpBuff\", 12f, new UnityEngine.Vector2(224f, 88f), new UnityEngine.Vector2(10f, -90f), true);\n\n    var item = find(root.transform, \"m_itemEmitterSlot\");\n    var image = item.GetComponent<UnityEngine.UI.Image>();\n    var oldButton = item.GetComponent<UnityEngine.UI.Button>();\n    var existingUIButton = item.GetComponent<GameLogic.UIButton>();\n    if (existingUIButton == null)\n    {\n        if (oldButton != null)\n        {\n            UnityEngine.Object.DestroyImmediate(oldButton, true);\n        }\n        existingUIButton = item.gameObject.AddComponent<GameLogic.UIButton>();\n    }\n    existingUIButton.targetGraphic = image;\n    existingUIButton.transition = UnityEngine.UI.Selectable.Transition.ColorTint;\n    existingUIButton.SetClickInterval(0.2f);\n\n    UnityEditor.PrefabUtility.SaveAsPrefabAsset(root, path);\n    UnityEditor.AssetDatabase.SaveAssets();\n    UnityEditor.AssetDatabase.Refresh();\n    return \"Saved BattleEmitterAddPanelWidget debug card layout and UIButton.\";\n}\nfinally\n{\n    UnityEditor.PrefabUtility.UnloadPrefabContents(root);\n}","safety_checks":true,"compiler":"codedom"}}
