{"ts":"2026-06-24T09:02:00.229Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":545,"action":"execute","params":{"action":"execute","code":"var stage = UnityEditor.SceneManagement.PrefabStageUtility.GetCurrentPrefabStage();\nif (stage == null || stage.prefabContentsRoot == null) return \"stage not found\";\nvar root = stage.prefabContentsRoot;\nvar bind = root.GetComponent<GameLogic.UIBindComponent>();\nif (bind == null) return \"bind missing\";\nUnityEngine.Component[] refs = new UnityEngine.Component[]\n{\n    root.transform.Find(\"m_tmpTitle\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tmpEmpty\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"visual_scrollViewport/m_tfOwnedEmitterItems\"),\n    root.transform.Find(\"visual_scrollViewport/m_tfOwnedEmitterItems/m_itemOwnedEmitter\").GetComponent<UnityEngine.RectTransform>(),\n    root.transform.Find(\"m_tfTunePanel\"),\n    root.transform.Find(\"m_tfTunePanel/m_tmpTuneTitle\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tfTunePanel/m_tmpTuneCooldown\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnCooldownMinus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnCooldownPlus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_tmpTuneRange\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnRangeMinus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnRangePlus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_tmpTuneHit\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnHitMinus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnHitPlus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_tmpTuneDamage\").GetComponent<TMPro.TextMeshProUGUI>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnDamageMinus\").GetComponent<GameLogic.UIButton>(),\n    root.transform.Find(\"m_tfTunePanel/m_btnDamagePlus\").GetComponent<GameLogic.UIButton>(),\n};\nfor (int i = 0; i < refs.Length; i++)\n{\n    if (refs[i] == null) return \"missing ref \" + i;\n}\nvar so = new UnityEditor.SerializedObject(bind);\nvar prop = so.FindProperty(\"m_components\");\nprop.arraySize = refs.Length;\nfor (int i = 0; i < refs.Length; i++)\n{\n    prop.GetArrayElementAtIndex(i).objectReferenceValue = refs[i];\n}\nso.ApplyModifiedProperties();\nUnityEditor.EditorUtility.SetDirty(bind);\nUnityEditor.EditorUtility.SetDirty(root);\nUnityEditor.PrefabUtility.SaveAsPrefabAsset(root, stage.assetPath);\nreturn \"bound \" + refs.Length;","language":"csharp"}}
