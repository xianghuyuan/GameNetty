{"ts":"2026-06-16T16:59:33.836Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":989,"action":"execute","params":{"action":"execute","code":"string sourceFontPath = \"Assets/AssetRaw/Fonts/SourceHanSansSC-Regular.otf\";\nstring newFontAssetPath = \"Assets/AssetRaw/Fonts/SourceHanSansSC-Regular SDF.asset\";\nstring oldFontAssetPath = \"Assets/AssetRaw/Fonts/XiaolaiSC-Regular SDF.asset\";\nstring tmpSettingsPath = \"Assets/TextMesh Pro/Resources/TMP Settings.asset\";\n\nUnityEditor.AssetDatabase.ImportAsset(sourceFontPath, UnityEditor.ImportAssetOptions.ForceUpdate);\nvar sourceFont = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEngine.Font>(sourceFontPath);\nif (sourceFont == null)\n{\n    return \"ERROR: Source font not found or not imported as Font: \" + sourceFontPath;\n}\n\nvar oldFont = UnityEditor.AssetDatabase.LoadAssetAtPath<TMPro.TMP_FontAsset>(oldFontAssetPath);\nif (oldFont == null)\n{\n    return \"ERROR: Old TMP font asset not found: \" + oldFontAssetPath;\n}\n\nvar newFont = UnityEditor.AssetDatabase.LoadAssetAtPath<TMPro.TMP_FontAsset>(newFontAssetPath);\nbool created = false;\nif (newFont == null)\n{\n    newFont = TMPro.TMP_FontAsset.CreateFontAsset(sourceFont);\n    if (newFont == null)\n    {\n        return \"ERROR: TMP_FontAsset.CreateFontAsset returned null for \" + sourceFontPath;\n    }\n    newFont.name = \"SourceHanSansSC-Regular SDF\";\n    try { newFont.atlasPopulationMode = TMPro.AtlasPopulationMode.Dynamic; } catch { }\n    if (newFont.material != null)\n    {\n        newFont.material.name = \"SourceHanSansSC-Regular Atlas Material\";\n    }\n    UnityEditor.AssetDatabase.CreateAsset(newFont, newFontAssetPath);\n    created = true;\n}\nelse\n{\n    try { newFont.atlasPopulationMode = TMPro.AtlasPopulationMode.Dynamic; } catch { }\n    if (newFont.material != null)\n    {\n        newFont.material.name = \"SourceHanSansSC-Regular Atlas Material\";\n    }\n    UnityEditor.EditorUtility.SetDirty(newFont);\n}\n\nvar tmpSettings = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEngine.Object>(tmpSettingsPath);\nif (tmpSettings == null)\n{\n    return \"ERROR: TMP Settings not found: \" + tmpSettingsPath;\n}\nvar settingsSo = new UnityEditor.SerializedObject(tmpSettings);\nvar defaultFontProp = settingsSo.FindProperty(\"m_defaultFontAsset\");\nif (defaultFontProp == null)\n{\n    return \"ERROR: TMP Settings missing m_defaultFontAsset property.\";\n}\ndefaultFontProp.objectReferenceValue = newFont;\nvar defaultPathProp = settingsSo.FindProperty(\"m_defaultFontAssetPath\");\nif (defaultPathProp != null)\n{\n    defaultPathProp.stringValue = \"AssetRaw/Fonts/\";\n}\nsettingsSo.ApplyModifiedPropertiesWithoutUndo();\nUnityEditor.EditorUtility.SetDirty(tmpSettings);\n\nint prefabsScanned = 0;\nint prefabsChanged = 0;\nint textChanged = 0;\nvar changedPrefabs = new System.Collections.Generic.List<string>();\nstring[] prefabGuids = UnityEditor.AssetDatabase.FindAssets(\"t:Prefab\", new string[] { \"Assets/AssetRaw/UI\" });\nforeach (string guid in prefabGuids)\n{\n    string path = UnityEditor.AssetDatabase.GUIDToAssetPath(guid);\n    var root = UnityEditor.PrefabUtility.LoadPrefabContents(path);\n    if (root == null)\n    {\n        continue;\n    }\n    prefabsScanned++;\n    bool changed = false;\n    try\n    {\n        var texts = root.GetComponentsInChildren<TMPro.TMP_Text>(true);\n        foreach (var text in texts)\n        {\n            if (text != null && text.font == oldFont)\n            {\n                text.font = newFont;\n                text.fontSharedMaterial = newFont.material;\n                UnityEditor.EditorUtility.SetDirty(text);\n                changed = true;\n                textChanged++;\n            }\n        }\n        if (changed)\n        {\n            UnityEditor.PrefabUtility.SaveAsPrefabAsset(root, path);\n            prefabsChanged++;\n            changedPrefabs.Add(path);\n        }\n    }\n    finally\n    {\n        UnityEditor.PrefabUtility.UnloadPrefabContents(root);\n    }\n}\n\nUnityEditor.AssetDatabase.SaveAssets();\nUnityEditor.AssetDatabase.Refresh();\n\nreturn \"created=\" + created\n    + \"\\nnewFont=\" + newFontAssetPath\n    + \"\\nsourceFont=\" + sourceFontPath\n    + \"\\nprefabsScanned=\" + prefabsScanned\n    + \"\\nprefabsChanged=\" + prefabsChanged\n    + \"\\ntextChanged=\" + textChanged\n    + \"\\nchangedPrefabs=\" + string.Join(\",\", changedPrefabs.ToArray());","safety_checks":true,"compiler":"auto"}}
