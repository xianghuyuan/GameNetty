   int totalWaves = stage.TotalWaves;
   List<int> waveIds = stage.WaveList;
   ```

2. **开始波次**:
   ```csharp
   WaveConfig wave = WaveConfigCategory.Instance.Get(waveId);
   foreach (var batch in wave.Batches) {
       // batch.SpawnId, batch.Delay
   }
   ```

3. **执行刷怪**:
   ```csharp
   SpawnTable spawn = SpawnTableCategory.Instance.Get(batch.SpawnId);
   foreach (var monster in spawn.Monsters) {
       // monster.MonsterId, monster.Count
       // 在 spawn.PositionX/Z 周围 spawn.SpreadRange 范围内生成
   }
   ```

